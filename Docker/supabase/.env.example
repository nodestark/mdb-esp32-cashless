# Environment variables for Supabase CLI (supabase start / supabase functions serve)
# Referenced by env() in config.toml [edge_runtime.secrets]
#
# Copy to .env and fill in values:
#   cp .env.example .env
#
# Or run the credential generator which updates this automatically:
#   cd Docker && ./mqtt-credentials.sh

# MQTT broker — use your LAN IP so edge functions can reach the broker
MQTT_HOST=localhost

# Shared secret between the MQTT forwarder and the mqtt-webhook edge function
MQTT_WEBHOOK_SECRET=change-me-to-a-random-secret

# MQTT admin credentials (used by edge functions to publish to broker)
MQTT_ADMIN_USER=admin
MQTT_ADMIN_PASS=admin

# Public Supabase URL reachable by ESP32 devices (LAN IP + CLI API port)
# Used by trigger-ota to build firmware download URLs the device can fetch
# Note: cannot use SUPABASE_ prefix — the CLI reserves it for internal use
PUBLIC_SUPABASE_URL=http://localhost:54321

# Public MQTT broker address returned to devices during provisioning
MQTT_PUBLIC_HOST=localhost
MQTT_PUBLIC_PORT=1883

# VAPID keys for Web Push notifications (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@localhost
