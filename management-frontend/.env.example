# Supabase connection (local dev uses Supabase CLI on port 54321)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_KEY=your-anon-key

# VAPID public key for push notifications (must match backend VAPID_PUBLIC_KEY)
VAPID_PUBLIC_KEY=

# GitHub repo for firmware release imports (owner/repo format, leave empty to disable)
GITHUB_FIRMWARE_REPO=
