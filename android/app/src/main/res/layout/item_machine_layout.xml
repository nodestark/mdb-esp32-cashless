<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:orientation="horizontal"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textViewMachineName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Machine Name"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/textViewMachineCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Category: Snack"
            android:textSize="13sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/textViewMachineLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Location: —"
            android:textSize="12sp"
            android:textColor="@color/text_tertiary" />

    </LinearLayout>

    <ImageButton
        android:id="@+id/btnEditMachine"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_edit"
        android:contentDescription="Edit machine" />

</LinearLayout>
