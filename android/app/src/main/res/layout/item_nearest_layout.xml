<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/containerNearestItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:orientation="horizontal"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical">

    <View
        android:id="@+id/viewNearestStatus"
        android:layout_width="4dp"
        android:layout_height="40dp"
        android:layout_marginEnd="8dp"
        android:background="@color/status_indicator" />

    <TextView
        android:id="@+id/textViewNearest"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="MQTT"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary" />

    <ImageButton
        android:id="@+id/btnSetPassword"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_lock_lock"
        android:contentDescription="Set password" />

</LinearLayout>
